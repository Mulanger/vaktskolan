{
  "name": "vaktskolan",
  "version": "2.0.0",
  "private": true,
  "description": "Vaktskolan public SEO site and legacy learning platform.",
  "scripts": {
    "prepare:assets": "node scripts/prepare-public-assets.mjs",
    "predev": "npm run prepare:assets",
    "dev": "next dev",
    "prebuild": "npm run prepare:assets && npm run validate:content && npm run validate:release && npm run validate:legacy && npm run test:platform-guards && npm run test:quiz-balance && npm run test:emblems && npm run test:billing",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:content": "tsx scripts/validate-content.ts",
    "content:manifest": "node scripts/content-release-manifest.mjs",
    "validate:release": "node scripts/content-release-manifest.mjs --check",
    "validate:legacy": "node --check app.js && node --check authProvider.js && node --check auth.js && node --check supabaseApi.js && node --check emblemSystem.js",
    "test:platform-guards": "node scripts/test-platform-guards.mjs",
    "test:quiz-balance": "node scripts/test-quiz-balance.mjs",
    "test:emblems": "node scripts/test-emblem-system.mjs",
    "test:billing": "tsx scripts/test-stripe-billing.ts",
    "verify:supabase-progress": "node scripts/verify-supabase-progress.mjs",
    "stripe:setup": "node --env-file=.env scripts/create-stripe-premium-product.mjs",
    "import:quiz-portal": "node scripts/import-quiz-portal-banks.mjs",
    "test:seo": "tsx scripts/test-seo.ts",
    "test": "npm run typecheck && npm run lint && npm run validate:content && npm run validate:release && npm run test:platform-guards && npm run test:quiz-balance && npm run test:emblems && npm run test:billing"
  },
  "dependencies": {
    "@clerk/backend": "^3.12.0",
    "gray-matter": "4.0.3",
    "jose": "^6.2.4",
    "next": "16.2.10",
    "next-mdx-remote": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "schema-dts": "1.1.5",
    "stripe": "^22.3.2",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.16"
  },
  "engines": {
    "node": ">=20.9"
  }
}
