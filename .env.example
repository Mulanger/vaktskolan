APP_ENV=production
SITE_URL=https://vaktskolan.se
# Local development only. This flag is ignored when APP_ENV=production.
ALLOW_UNAUTHENTICATED_PLATFORM_PREVIEW=false
GOOGLE_SITE_VERIFICATION=your-google-search-console-token
BING_SITE_VERIFICATION=your-bing-webmaster-tools-token

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
SUPABASE_SECRET_KEY=sb_secret_your_server_only_secret_key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_FRONTEND_API_URL=https://clerk.vaktskolan.se
CLERK_BACKEND_API_URL=https://api.clerk.com
CLERK_JWKS_URL=https://clerk.vaktskolan.se/.well-known/jwks.json
